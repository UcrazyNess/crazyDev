# --- Server Configuration ---
# پورت سرور (ترجیحاً در محیط تست و عملیاتی متفاوت باشد)
SERVER_PORT=
# حالت اجرا (توصیه می‌شود: development, staging, production)
APP_ENV=

# --- Database Configuration ---
# مسیر دیتابیس یا Connection String
# در محیط‌های حرفه‌ای از آدرس اتصال استفاده می‌شود
DB_DRIVER=
DB_PATH=

# --- Security & Features ---
# استفاده از نام‌های توصیفی‌تر به جای ALLOW_ALL
# (مثلاً تعیین سطح دسترسی یا فعال/غیرفعال کردن حالت دیباگ)
DEBUG_MODE=
ENABLE_PUBLIC_ACCESS=

# --- API Keys / Secrets ---
# همیشه مقادیر حساس را در متغیرهای جداگانه قرار دهید
JWT_SECRET=